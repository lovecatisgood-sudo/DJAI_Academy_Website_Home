{
  "name": "djaytools-qr-generator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build-root-hostinger.mjs",
    "build:app": "next build && node scripts/set-export-language.mjs",
    "build:hostinger": "node scripts/build-root-hostinger.mjs",
    "start": "node scripts/start-root-hostinger.mjs",
    "test": "npm run test:hostinger",
    "test:hostinger": "npm run build:app && node --test tests/static-export.test.mjs",
    "lint": "eslint app --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.6",
    "qr-code-styling": "^1.9.2",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "js-yaml": "4.2.0",
    "postcss": "8.5.10"
  },
  "type": "module",
  "displayName": "DJayTools Free QR Generator"
