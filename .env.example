# Required to sign in and publish through /admin/blog/.
DJAI_BLOG_ADMIN_PASSWORD=

# Optional but recommended for agent autoposting through /api/admin/blog.
# Generate a long random value and store it only in Hostinger/runtime secrets.
DJAI_BLOG_API_KEY=

# Optional. Use an absolute persistent path on the server if blog posts must survive redeployments.
# DJAI_BLOG_DATA_FILE=/absolute/path/to/blog-posts.json
